# ============================================
# Catalyze Production Environment Configuration
# ============================================
# Copy this to .env and fill in all values before deploying.

NODE_ENV=production

# ---- Frontend ----
VITE_API_URL=https://api.catalyze.app/api
VITE_GOOGLE_CLIENT_ID=your-production-google-client-id

# ---- Server ----
PORT=4000
CORS_ORIGIN=https://catalyze.app

# ---- Database (AWS RDS MSSQL) ----
DB_HOST=your-rds-endpoint.amazonaws.com
DB_PORT=1433
DB_NAME=catalyze
DB_USER=catalyze_admin
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=false

# ---- Authentication ----
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_GENERATE_WITH_CRYPTO_RANDOM_BYTES
JWT_REFRESH_SECRET=CHANGE_THIS_GENERATE_DIFFERENT_SECRET
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_REMEMBER_EXPIRES_IN=7d
JWT_REFRESH_REMEMBER_EXPIRES_IN=90d

# ---- Apple Sign-In ----
APPLE_CLIENT_ID=com.catalyze.app
APPLE_TEAM_ID=YOUR_APPLE_TEAM_ID
APPLE_KEY_ID=YOUR_APPLE_KEY_ID

# ---- Google OAuth ----
GOOGLE_CLIENT_ID=your-production-google-client-id

# ---- OpenAI ----
OPENAI_API_KEY=sk-your-openai-api-key

# ---- Twilio (SMS OTP) ----
TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# ---- AWS S3 (Media Uploads - future) ----
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=catalyze-uploads
